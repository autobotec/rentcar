{
  "name": "rentacar-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace web run dev",
    "dev:api": "npm --workspace api run start:dev",
    "dev": "npm run dev:api & npm run dev:web",
    "build:web": "npm --workspace web run build",
    "build:api": "npm --workspace api run build",
    "build": "npm run build:api && npm run build:web",
    "lint": "npm --workspace web run lint && npm --workspace api run lint",
    "db:seed": "node scripts/seed.js"
  },
  "devDependencies": {
    "prisma": "6.19.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  }
}
